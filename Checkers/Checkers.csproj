<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\BlackCheckedField.png" />
    <None Remove="Assets\BlackChecker.png" />
    <None Remove="Assets\Field.png" />
    <None Remove="Assets\KingBlackChecker.png" />
    <None Remove="Assets\KingWhiteChecker.png" />
    <None Remove="Assets\WhiteCheckedField.png" />
    <None Remove="Assets\WhiteChecker.png" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\KingBlackChecker.png">
